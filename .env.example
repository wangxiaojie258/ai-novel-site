# --- Astro / Site ---
PUBLIC_SITE_URL=https://ai-novel.example.com
PUBLIC_SITE_NAME="AI Novel Site"
PUBLIC_DEFAULT_LOCALE=zh

# --- Cloudflare Pages (optional, set in CF dashboard too) ---
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_PROJECT_NAME=ai-novel-site

# --- D1 / KV / R2 bindings (use IDs from `wrangler` commands) ---
D1_DATABASE_ID=
D1_DATABASE_NAME=ai_novel_db
KV_NAMESPACE_ID=
R2_BUCKET_NAME=ai-novel-assets

# --- JWT / Auth ---
JWT_SECRET=change-me-to-a-32-byte-random-string
JWT_EXPIRES_IN=7d

# --- AI verification ---
AI_VERIFY_HMAC_SECRET=change-me-hmac-secret-for-ai-uploads
AI_VERIFY_TIMESTAMP_TOLERANCE=300
AI_VERIFY_NONCE_TTL=600

# --- Reward / Payment (placeholders) ---
REWARD_PROVIDER=stub
REWARD_WEBHOOK_SECRET=

# --- Workers AI (Cloudflare) ---
CF_AI_ACCOUNT_ID=
CF_AI_API_TOKEN=
