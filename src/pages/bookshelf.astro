---
import BaseLayout from '../layouts/BaseLayout.astro';
import BookGrid from '../components/BookGrid.astro';
import { resolveLocale, t } from '../i18n';

export const prerender = false;

const locale = resolveLocale(Astro.url.searchParams.get('lang'));
const session = (Astro.locals as Record<string, unknown>).session as
  | { sub: string; role: string; username?: string }
  | null;

let books: Array<{
  id: string;
  title: string;
  author: string;
  cover: string;
  status: 'ongoing' | 'completed';
  category: string;
  chapterCount: number;
  wordCount: number;
  href: string;
}> = [];

if (session) {
  try {
    const res = await fetch(new URL('/api/bookshelf', Astro.url.origin), {
      headers: { Cookie: `session=${Astro.cookies.get('session')?.value ?? ''}` },
    });
    if (res.ok) {
      const data = await res.json() as { books?: Array<Record<string, unknown>> };
      books = (data.books ?? []).map((b: Record<string, unknown>) => ({
        id: b.novel_id as string,
        title: b.novel_title as string,
        author: b.novel_author as string,
        cover: b.novel_cover as string,
        status: 'ongoing' as const,
        category: 'male' as const,
        chapterCount: 0,
        wordCount: 0,
        href: `/novels/${b.novel_id}`,
      }));
    }
  } catch {
    // fallback to empty
  }
}
---

<BaseLayout title={t(locale, 'bookshelf.title')} locale={locale}>
  <div class="page">
    <h1 class="page__title">{t(locale, 'bookshelf.title')}</h1>
    <p class="page__subtitle">{t(locale, 'bookshelf.subtitle')}</p>

    {
      !session ? (
        <div class="empty-state">
          <p>{t(locale, 'bookshelf.loginRequired')}</p>
          <a href="/login" class="mt-2">
            <button class="primary" type="button">{t(locale, 'auth.login')}</button>
          </a>
        </div>
      ) : books.length === 0 ? (
        <div class="empty-state">
          <p>{t(locale, 'bookshelf.empty')}</p>
          <a href="/novels" class="mt-2">
            <button class="primary" type="button">{t(locale, 'bookshelf.browse')}</button>
          </a>
        </div>
      ) : (
        <BookGrid books={books} locale={locale} variant="novel" emptyText={t(locale, 'bookshelf.empty')} />
      )
    }
  </div>
</BaseLayout>

<style>
  .page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }
  .page__title {
    font-size: 2rem;
    font-weight: 700;
    margin: 0 0 0.25rem;
  }
  .page__subtitle {
    color: var(--color-muted, #888);
    margin: 0 0 2rem;
  }
  .empty-state {
    text-align: center;
    padding: 4rem 2rem;
    background: var(--color-surface, #1a1a2e);
    border-radius: 12px;
    border: 1px solid var(--color-border, #2a2a4a);
  }
  .empty-state p {
    color: var(--color-muted, #888);
    font-size: 1.1rem;
    margin-bottom: 1rem;
  }
  .mt-2 { display: inline-block; margin-top: 0.5rem; }
  .primary {
    padding: 0.7rem 1.5rem;
    background: var(--color-accent, #7c5cfc);
    color: white;
    border: none;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
  }
  .primary:hover { opacity: 0.9; }
</style>
