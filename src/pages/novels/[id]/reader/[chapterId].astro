---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Reader from '../../../../components/Reader.astro';
import CommentSection from '../../../../components/CommentSection.astro';
import { resolveLocale } from '../../../../i18n';

export const prerender = false;

const locale = resolveLocale(Astro.url.searchParams.get('lang'));
const { id, chapterId } = Astro.params;

const allNovels = await getCollection('novels');
const novelEntry = allNovels.find((e) => e.id === id);

const allChapters = await getCollection('chapters');
const chapterEntry = allChapters.find((c) => c.id === chapterId);

if (!chapterEntry || !novelEntry) {
  return Astro.redirect(`/novels/${id}`);
}

const novel = novelEntry.data;
const chapter = chapterEntry;

const novelChapters = allChapters
  .filter((c) => c.data.novelId === id)
  .sort((a, b) => a.data.chapterNumber - b.data.chapterNumber);

const curIdx = novelChapters.findIndex((c) => c.id === chapterId);
const prevCh = curIdx > 0 ? novelChapters[curIdx - 1] : null;
const nextCh = curIdx < novelChapters.length - 1 ? novelChapters[curIdx + 1] : null;

const bookHref = `/novels/${id}`;
const prevHref = prevCh ? `/novels/${id}/reader/${prevCh.id}` : undefined;
const nextHref = nextCh ? `/novels/${id}/reader/${nextCh.id}` : undefined;

const chapterData = {
  id: chapterEntry.id,
  number: chapter.data.chapterNumber,
  title: chapter.data.title,
  contentHtml: chapter.body
    ? (() => {
        const raw = chapter.body
          .replace(/^---[\s\S]*?---/, '')
          .replace(/^#+\s+.*$/gm, '')
          .trim();
        // Split into paragraphs, then split each paragraph into sentences
        const paragraphs = raw.split(/\n\n+/);
        const sentences: string[] = [];
        for (const p of paragraphs) {
          const trimmed = p.trim();
          if (!trimmed) continue;
          if (trimmed.startsWith('<')) {
            sentences.push(trimmed);
            continue;
          }
          // Split by Chinese sentence-ending punctuation, keeping the delimiter
          // Also handle English-like content with .!? followed by space
          const parts = trimmed
            .split(/(?<=[。？！…])|(?<=[.!?])(?=\s+)/)
            .filter(s => s.trim());
          sentences.push(...parts.map(s => `<p>${s.trim()}</p>`));
        }
        return sentences.join('\n');
      })()
    : '<p>章节内容为空</p>',
  wordCount: chapter.data.wordCount ?? 0,
  publishDate: chapter.data.publishDate ? new Date(chapter.data.publishDate) : new Date(),
};

const bookTitle = novel.title;

const session = (Astro.locals as Record<string, unknown>).session as
  | { sub: string; role: string; username?: string }
  | null;

const chapterJson = JSON.stringify({
  novelId: id,
  chapterId: chapterId,
  chapterNumber: chapterData.number,
  chapterTitle: chapterData.title,
});
---

<BaseLayout title={`${chapterData.title} - ${bookTitle}`}>
  <Reader
    bookTitle={bookTitle}
    bookHref={bookHref}
    chapter={chapterData}
    prevHref={prevHref}
    nextHref={nextHref}
    locale={locale}
  />
  <div class="container">
    <CommentSection
      comments={[]}
      targetType="chapter"
      targetId={chapterEntry.id}
      locale={locale}
      loginRequired
      isLoggedIn={!!session}
    />
  </div>
</BaseLayout>

{session && (
  <script>
    const ch = JSON.parse('{chapterJson}');
    let saved = false;

    function saveProgress() {
      if (saved) return;
      const scrollTop = window.scrollY || document.documentElement.scrollTop;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const position = docHeight > 0 ? Math.min(100, Math.round((scrollTop / docHeight) * 100)) : 0;

      if (position < 10 && docHeight > 2000) return;

      saved = true;
      fetch('/api/progress', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ ...ch, position }),
      }).catch(() => { saved = false; });
    }

    // Save on scroll near bottom
    let scrollTimer: ReturnType<typeof setTimeout>;
    window.addEventListener('scroll', () => {
      clearTimeout(scrollTimer);
      scrollTimer = setTimeout(() => {
        const atBottom = window.scrollY + window.innerHeight >= document.documentElement.scrollHeight - 300;
        if (atBottom) saveProgress();
      }, 500);
    }, { passive: true });

    // Save on page unload
    window.addEventListener('beforeunload', saveProgress);
  </script>
)}
