---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ChapterList from '../../../components/ChapterList.astro';
import CommentSection from '../../../components/CommentSection.astro';
import { resolveLocale, t } from '../../../i18n';

export const prerender = false;

const locale = resolveLocale(Astro.url.searchParams.get('lang'));
const { id } = Astro.params;

const classic = {
  id: id ?? 'demo-classic-1',
  title: '红楼梦',
  author: '曹雪芹',
  dynasty: '清',
  category: '古典小说',
  tags: ['古典', '章回体', '长篇'],
  excerpt: '中国古典章回体小说的巅峰之作，被誉为"中国封建社会的百科全书"。',
  wordCount: 730_000,
  chapterCount: 120,
  publishDate: new Date('1791-01-01'),
};

const chapters = Array.from({ length: 20 }, (_, i) => ({
  id: `ch-${i + 1}`,
  number: i + 1,
  title: `第 ${i + 1} 回`,
  wordCount: 6000 + (i % 4) * 1200,
  publishDate: classic.publishDate,
  href: `/classics/${classic.id}/reader/ch-${i + 1}`,
}));
---

<BaseLayout title={classic.title} description={classic.excerpt}>
  <article class="page">
    <header>
      <h1 class="page__title">{classic.title}</h1>
      <p class="page__subtitle text-muted">
        {t(locale, 'book.author')}: {classic.author} · {classic.dynasty} · {classic.category}
      </p>
    </header>

    <section class="mt-2">
      <h2 class="text-muted">{t(locale, 'book.excerpt')}</h2>
      <p>{classic.excerpt}</p>
    </section>

    <section>
      <h2 class="text-muted">{t(locale, 'book.tags')}</h2>
      <p>{classic.tags.join('、')}</p>
    </section>

    <h2 class="text-muted">{t(locale, 'book.chapters')}</h2>
    <ChapterList chapters={chapters} locale={locale} />

    <CommentSection
      comments={[]}
      targetType="book"
      targetId={classic.id}
      locale={locale}
      loginRequired
    />
  </article>
</BaseLayout>
