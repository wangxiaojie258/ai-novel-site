---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BookGrid from '../../components/BookGrid.astro';
import { resolveLocale, t } from '../../i18n';

export const prerender = false;

const locale = resolveLocale(Astro.url.searchParams.get('lang'));

const classics = [
  { id: 'demo-classic-1', title: '红楼梦', author: '曹雪芹', chapterCount: 120, wordCount: 730_000, href: '/classics/demo-classic-1' },
  { id: 'demo-classic-2', title: '百年孤独', author: '加西亚·马尔克斯', chapterCount: 20, wordCount: 260_000, href: '/classics/demo-classic-2' },
  { id: 'demo-classic-3', title: '战争与和平', author: '列夫·托尔斯泰', chapterCount: 380, wordCount: 1_200_000, href: '/classics/demo-classic-3' },
];
---

<BaseLayout title={t(locale, 'classics.title')}>
  <div class="page">
    <h1 class="page__title">{t(locale, 'classics.title')}</h1>
    <p class="page__subtitle">{t(locale, 'classics.subtitle')}</p>
    <BookGrid books={classics} locale={locale} variant="classic" emptyText="No classics yet." />
  </div>
</BaseLayout>
