---
import { DEFAULT_LOCALE, type Locale, t } from '../i18n';

interface Props {
  locale?: Locale;
  session?: { sub: string; role: string; username?: string } | null;
}

const { locale = DEFAULT_LOCALE, session = null } = Astro.props;

const navItems: { href: string; key: string }[] = [
  { href: '/', key: 'nav.home' },
  { href: '/novels', key: 'nav.novels' },
  { href: '/classics', key: 'nav.classics' },
  { href: '/rankings', key: 'nav.rankings' },
  { href: '/ai-creators', key: 'nav.aiCreators' },
  { href: '/about', key: 'nav.about' },
  { href: '/prompts', key: 'nav.prompts' },
  { href: '/ai-literature', key: 'nav.aiLiterature' },
  { href: '/bookshelf', key: 'nav.bookshelf' },
  { href: '/submit', key: 'nav.submit' },
];

const current = Astro.url.pathname;
---

<header class="site-header">
  <div class="container site-header__inner">
    <a href="/" class="site-header__brand">{t(locale, 'site.name')}</a>
    <nav class="site-header__nav" aria-label="primary">
      {
        navItems.map((item) => {
          const active = current === item.href || (item.href !== '/' && current.startsWith(item.href));
          return (
            <a href={item.href} class={active ? 'active' : ''}>
              {t(locale, item.key)}
            </a>
          );
        })
      }
    </nav>
    <div class="site-header__actions">
      <form class="search-form" action="/search" method="GET">
        <input type="search" name="q" placeholder="搜索小说..." class="search-input" />
      </form>
      {session ? (
        <div class="user-menu">
          <span class="user-name">{session.username ?? session.sub}</span>
          <button class="logout-btn" id="logout-btn" title={t(locale, 'auth.logout')}>
            {t(locale, 'auth.logout')}
          </button>
        </div>
      ) : (
        <a href="/login" class="login-link">{t(locale, 'auth.login')}</a>
      )}
    </div>
  </div>
</header>

<script>
  const logoutBtn = document.getElementById('logout-btn');
  if (logoutBtn) {
    logoutBtn.addEventListener('click', () => {
      document.cookie = 'session=;path=/;max-age=0;SameSite=Lax';
      window.location.href = '/';
    });
  }
</script>

<style>
  .user-menu {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .user-name {
    color: var(--color-accent, #7c5cfc);
    font-weight: 600;
    font-size: 0.9rem;
  }
  .logout-btn {
    background: none;
    border: 1px solid var(--color-border, #2a2a4a);
    border-radius: 6px;
    color: var(--color-muted, #888);
    padding: 0.3rem 0.6rem;
    font-size: 0.8rem;
    cursor: pointer;
    transition: all 0.2s;
  }
  .logout-btn:hover {
    border-color: #f87171;
    color: #f87171;
  }
  .login-link {
    color: var(--color-accent, #7c5cfc);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
  }
  .login-link:hover { text-decoration: underline; }
  .search-form { margin-right: 0.5rem; }
  .search-input {
    padding: 0.35rem 0.7rem;
    background: var(--color-bg, #0f0f23);
    border: 1px solid var(--color-border, #2a2a4a);
    border-radius: 6px;
    color: var(--color-text, #e0e0e0);
    font-size: 0.85rem;
    width: 140px;
    transition: border-color 0.2s, width 0.2s;
  }
  .search-input:focus {
    outline: none;
    border-color: var(--color-accent, #7c5cfc);
    width: 200px;
  }
  .search-input::placeholder { color: var(--color-muted, #888); }
</style>
